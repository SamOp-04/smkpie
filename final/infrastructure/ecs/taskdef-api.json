{
  "family": "smkpie-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::371601828313:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::371601828313:role/smkpieEcsTaskRole",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "371601828313.dkr.ecr.ap-south-1.amazonaws.com/smkpie-runtime@sha256:e46725bd9e8cd523a9f8c60a21e946aaa6fdf5529bdc45ba1b10281710fabe41",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "command": [
        "uvicorn",
        "main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/smkpie-api",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "environment": [
        { "name": "REDIS_HOST", "value": "localhost" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "MODEL_UPDATE_INTERVAL", "value": "3600" },
        { "name": "ANOMALY_THRESHOLD", "value": "0.7" },
        { "name": "MAX_REQUESTS_PER_MINUTE", "value": "100" },
        { "name": "AWS_REGION", "value": "ap-south-1" },
        { "name": "S3_BUCKET", "value": "smkpie-models" },
        { "name": "SMTP_HOST", "value": "smtp.gmail.com" },
        { "name": "SMTP_PORT", "value": "587" },
        { "name": "EMAIL_SENDER", "value": "noreply@smkpie.local" }
      ],
      "secrets": [
        { "name": "SUPABASE_URL", "valueFrom": "arn:aws:ssm:ap-south-1:371601828313:parameter/smkpie/SUPABASE_URL" },
        { "name": "SUPABASE_KEY", "valueFrom": "arn:aws:ssm:ap-south-1:371601828313:parameter/smkpie/SUPABASE_KEY" },
        { "name": "SUPABASE_SERVICE_ROLE_KEY", "valueFrom": "arn:aws:ssm:ap-south-1:371601828313:parameter/smkpie/SUPABASE_SERVICE_ROLE_KEY" },
        { "name": "SUPABASE_JWT_SECRET", "valueFrom": "arn:aws:ssm:ap-south-1:371601828313:parameter/smkpie/SUPABASE_JWT_SECRET" },
        { "name": "REDIS_PASSWORD", "valueFrom": "arn:aws:ssm:ap-south-1:371601828313:parameter/smkpie/REDIS_PASSWORD" },
        { "name": "AWS_ACCESS_KEY_ID", "valueFrom": "arn:aws:ssm:ap-south-1:371601828313:parameter/smkpie/AWS_ACCESS_KEY_ID" },
        { "name": "AWS_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:ssm:ap-south-1:371601828313:parameter/smkpie/AWS_SECRET_ACCESS_KEY" },
        { "name": "SMTP_USER", "valueFrom": "arn:aws:ssm:ap-south-1:371601828313:parameter/smkpie/SMTP_USER" },
        { "name": "SMTP_PASSWORD", "valueFrom": "arn:aws:ssm:ap-south-1:371601828313:parameter/smkpie/SMTP_PASSWORD" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fsS http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
